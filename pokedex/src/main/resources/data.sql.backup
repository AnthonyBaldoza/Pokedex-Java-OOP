(68, 'Machamp',     'Fighting', NULL,      1.6,  130.0, 'Using its amazing muscles, it throws powerful punches that can knock the victim clear over the horizon.', 90,  130, 80,  65,  85,  55,  false, false),
(69, 'Bellsprout',  'Grass',    'Poison',  0.7,  4.0,   'A carnivorous Pokémon that traps and eats bugs. It uses its root feet to soak up needed moisture.',      50,  75,  35,  70,  30,  40,  false, false),
