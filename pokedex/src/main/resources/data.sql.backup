(53, 'Persian',     'Normal',   NULL,      1.0,  32.0,  'Although its fur has many admirers, it is tough to raise as a pet because of its fickle meanness.',       65,  70,  60,  65,  65,  115, false, false),
(54, 'Psyduck',     'Water',    NULL,      0.8,  19.6,  'While lulling its enemies with its vacant look, it will use its psychic powers.',                         50,  52,  48,  65,  50,  55,  false, false),
(55, 'Golduck',     'Water',    NULL,      1.7,  76.6,  'Often seen swimming elegantly by lake shores. It is often mistaken for the Japanese monster Kappa.',      80,  82,  78,  95,  80,  85,  false, false),
(56, 'Mankey',      'Fighting', NULL,      0.5,  28.0,  'Extremely quick to anger. It could be docile one moment then thrashing away the next instant.',           40,  80,  35,  35,  45,  70,  false, false),
(57, 'Primeape',    'Fighting', NULL,      1.0,  32.0,  'Always furious and tenacious to boot. It will not abandon chasing its quarry until it catches it.',       65,  105, 60,  60,  70,  95,  false, false),
(58, 'Growlithe',   'Fire',     NULL,      0.7,  19.0,  'Very protective of its territory. It will bark and bite to repel intruders from its space.',              55,  70,  45,  70,  50,  60,  false, false),
(59, 'Arcanine',    'Fire',     NULL,      1.9,  155.0, 'A Pokémon that has been admired since the past for its beauty. It runs agilely as if on wings.',          90,  110, 80,  100, 80,  95,  false, false),
(60, 'Poliwag',     'Water',    NULL,      0.6,  12.4,  'Its newly grown legs prevent it from running. It appears to prefer swimming over everything.',             40,  50,  40,  40,  40,  90,  false, false),
(61, 'Poliwhirl',   'Water',    NULL,      1.0,  20.0,  'Capable of living in or out of water. When out of water, it sweats to keep its body slimy.',              65,  65,  65,  50,  50,  90,  false, false),
(62, 'Poliwrath',   'Water',    'Fighting',1.3,  54.0,  'An adept swimmer at both the front crawl and breaststroke. Easily overtakes the best human swimmers.',    90,  95,  95,  70,  90,  70,  false, false),
(63, 'Abra',        'Psychic',  NULL,      0.9,  19.5,  'Using its ability to read minds, it will identify impending danger and teleport to safety.',              25,  20,  15,  105, 55,  90,  false, false),
