(21, 'Spearow',     'Normal',   'Flying',  0.3,  2.0,   'Eats bugs in grassy areas. It has to flap its short wings at high speed to stay airborne.',              40,  60,  30,  31,  31,  70,  false, false),
(22, 'Fearow',      'Normal',   'Flying',  1.2,  38.0,  'With its huge and magnificent wings, it can keep aloft without ever having to land for rest.',            65,  90,  65,  61,  61,  100, false, false),
