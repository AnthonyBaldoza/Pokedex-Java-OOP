(25, 'Pikachu',     'Electric', NULL,      0.4,  6.0,   'When several of these Pokémon gather, their electricity could build and cause lightning storms.',         35,  55,  40,  50,  50,  90,  false, false),
(26, 'Raichu',      'Electric', NULL,      0.8,  30.0,  'If the electrical sacks become excessively charged, Raichu plants its tail in the ground and discharges.', 60, 90, 55, 90, 80, 110, false, false),
(27, 'Sandshrew',   'Ground',   NULL,      0.6,  12.0,  'Burrows deep underground in arid locations far from water. It only emerges to hunt for food.',            50,  75,  85,  20,  30,  40,  false, false),
(28, 'Sandslash',   'Ground',   NULL,      1.0,  29.5,  'Curls up into a spiny ball when threatened. It can roll while curled up to attack or escape.',            75,  100, 110, 45,  55,  65,  false, false),
(29, 'NidoranF',    'Poison',   NULL,      0.4,  7.0,   'Although small, its venomous barbs render this Pokémon dangerous. The female has smaller horns.',         55,  47,  52,  40,  40,  41,  false, false),
(30, 'Nidorina',    'Poison',   NULL,      0.8,  20.0,  'The female''s horn develops slowly. Prefers physical attacks such as clawing and biting.',                70,  62,  67,  55,  55,  56,  false, false),
(31, 'Nidoqueen',   'Poison',   'Ground',  1.3,  60.0,  'Its hard scales provide strong protection. It uses its hefty bulk to execute powerful moves.',            90,  92,  87,  75,  85,  76,  false, false),
(32, 'NidoranM',    'Poison',   NULL,      0.5,  9.0,   'Stiffens its ears to sense danger. The larger its horns, the more powerful its secreted venom.',         46,  57,  40,  40,  40,  50,  false, false),
(33, 'Nidorino',    'Poison',   NULL,      0.9,  19.5,  'It is hot-tempered and quick to attack. The horn on its head secretes a powerful venom.',                 61,  72,  57,  55,  55,  65,  false, false),
(34, 'Nidoking',    'Poison',   'Ground',  1.4,  62.0,  'It uses its powerful tail in battle to smash, constrict, then break the prey''s bones.',                 81,  102, 77,  85,  75,  85,  false, false),
(35, 'Clefairy',    'Normal',   NULL,      0.6,  7.5,   'Its magical and cute appeal has many admirers. It is rare and found only in certain areas.',              70,  45,  48,  60,  65,  35,  false, false),
(36, 'Clefable',    'Normal',   NULL,      1.3,  40.0,  'A timid fairy Pokémon that is rarely seen. It will run and hide the moment it senses people.',            95,  70,  73,  95,  90,  60,  false, false),
