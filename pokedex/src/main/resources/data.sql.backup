INSERT INTO pokemon (pokemon_number, name, type, type2, height, weight, description, hp, attack, defense, special_attack, special_defense, speed, caught, favorite) VALUES
(1,  'Bulbasaur',   'Grass',    'Poison',  0.7,  6.9,   'A strange seed was planted on its back at birth. The plant sprouts and grows with this Pokémon.',      45,  49,  49,  65,  65,  45,  false, false),
(2,  'Ivysaur',     'Grass',    'Poison',  1.0,  13.0,  'When the bulb on its back grows large, it appears to lose the ability to stand on its hind legs.',       60,  62,  63,  80,  80,  60,  false, false),
(3,  'Venusaur',    'Grass',    'Poison',  2.0,  100.0, 'The plant blooms when it is absorbing solar energy. It stays on the move to seek sunlight.',              80,  82,  83,  100, 100, 80,  false, false),
(4,  'Charmander',  'Fire',     NULL,      0.6,  8.5,   'The flame at the tip of its tail makes a sound as it burns. You can only hear it in quiet places.',      39,  52,  43,  60,  50,  65,  false, false),
(5,  'Charmeleon',  'Fire',     NULL,      1.1,  19.0,  'When it swings its burning tail, it elevates the temperature to unbearably high levels.',                58,  64,  58,  80,  65,  80,  false, false),
(6,  'Charizard',   'Fire',     'Flying',  1.7,  90.5,  'It spits fire that is hot enough to melt boulders. It may cause forest fires by blowing flames.',        78,  84,  78,  109, 85,  100, false, false),
(7,  'Squirtle',    'Water',    NULL,      0.5,  9.0,   'After birth, its back swells and hardens into a shell. It powerfully sprays foam from its mouth.',       44,  48,  65,  50,  64,  43,  false, false),
(8,  'Wartortle',   'Water',    NULL,      1.0,  22.5,  'It is recognized as a symbol of longevity. If its shell has algae on it, that Wartortle is very old.',   59,  63,  80,  65,  80,  58,  false, false),
(9,  'Blastoise',   'Water',    NULL,      1.6,  85.5,  'It crushes its foe under its heavy body to cause fainting. In a pinch, it will withdraw inside its shell.', 79, 83, 100, 85, 105, 78, false, false),
(10, 'Caterpie',    'Bug',      NULL,      0.3,  2.9,   'Its short feet are tipped with suction pads that enable it to tirelessly climb slopes and walls.',       45,  30,  35,  20,  20,  45,  false, false),
(11, 'Metapod',     'Bug',      NULL,      0.7,  9.9,   'This Pokémon is vulnerable to attack while its shell is soft, exposing its weak and tender body.',       50,  20,  55,  25,  25,  30,  false, false),
(12, 'Butterfree',  'Bug',      'Flying',  1.1,  32.0,  'In battle, it flaps its wings at high speed to release highly toxic dust into the air.',                 60,  45,  50,  90,  80,  70,  false, false),
(13, 'Weedle',      'Bug',      'Poison',  0.3,  3.2,   'Often found in forests, eating leaves. It has a sharp venomous stinger on its head.',                    40,  35,  30,  20,  20,  50,  false, false),
(14, 'Kakuna',      'Bug',      'Poison',  0.6,  10.0,  'Almost incapable of moving, this Pokémon can only harden its shell to protect itself from predators.',   45,  25,  50,  25,  25,  35,  false, false),
(15, 'Beedrill',    'Bug',      'Poison',  1.0,  29.5,  'It has three poisonous stingers on its forelegs and its tail. They are used to jab its enemy repeatedly.', 65, 90, 40, 45, 80, 75, false, false),
(16, 'Pidgey',      'Normal',   'Flying',  0.3,  1.8,   'A common sight in forests and woods. It flaps its wings at ground level to kick up blinding sand.',      40,  45,  40,  35,  35,  56,  false, false),
(17, 'Pidgeotto',   'Normal',   'Flying',  1.1,  30.0,  'It is capable of uprooting a tree with a swipe of its thick, powerful wings.',                           63,  60,  55,  50,  50,  71,  false, false),
(18, 'Pidgeot',     'Normal',   'Flying',  1.5,  39.5,  'This Pokémon flies at Mach 2 speed, seeking prey. Its large talons are feared as wicked weapons.',       83,  80,  75,  70,  70,  101, false, false),
(19, 'Rattata',     'Normal',   NULL,      0.3,  3.5,   'Will chew on anything with its tough fangs. It can even gnaw through concrete.',                         30,  56,  35,  25,  35,  72,  false, false),
