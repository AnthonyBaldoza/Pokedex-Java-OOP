(38, 'Ninetales',   'Fire',     NULL,      1.1,  19.9,  'Very smart and very vengeful. Grabbing one of its many tails could result in a 1000-year curse.',         73,  76,  75,  81,  100, 100, false, false),
(39, 'Jigglypuff',  'Normal',   NULL,      0.5,  5.5,   'When its huge eyes light up, it sings a mysteriously soothing melody that lulls its enemies to sleep.',  115, 45,  20,  45,  25,  20,  false, false),
(40, 'Wigglytuff',  'Normal',   NULL,      1.0,  12.0,  'The body is soft and rubbery. When angered, it will suck in air and inflate itself to an enormous size.', 140, 70, 45, 85, 50, 45, false, false),
(41, 'Zubat',       'Poison',   'Flying',  0.8,  7.5,   'Forms colonies in perpetually dark places. Uses ultrasonic waves to identify and approach targets.',      40,  45,  35,  30,  40,  55,  false, false),
(42, 'Golbat',      'Poison',   'Flying',  1.6,  55.0,  'Once it bites, it will not stop draining energy from the victim even if it gets too heavy to fly.',       75,  80,  70,  65,  75,  90,  false, false),
(43, 'Oddish',      'Grass',    'Poison',  0.5,  5.4,   'During the day, it keeps its face buried in the ground. At night, it wanders around sowing its seeds.',  45,  50,  55,  75,  65,  30,  false, false),
(44, 'Gloom',       'Grass',    'Poison',  0.8,  8.6,   'The foul fluid oozing from its mouth is not drool. It is a nectar that is used to attract prey.',         60,  65,  70,  85,  75,  40,  false, false),
(45, 'Vileplume',   'Grass',    'Poison',  1.2,  18.6,  'The larger its petals, the more toxic pollen it contains. Its big head is heavy and hard to hold up.',   75,  80,  85,  110, 90,  50,  false, false),
(46, 'Paras',       'Bug',      'Grass',   0.3,  5.4,   'Burrows to suck tree roots. The mushrooms on its back grow by drawing nutrients from the bug host.',     35,  70,  55,  45,  55,  25,  false, false),
(47, 'Parasect',    'Bug',      'Grass',   1.0,  29.5,  'A host-parasite pair in which the parasite mushroom has taken over the host bug.',                        60,  95,  80,  60,  80,  30,  false, false),
(48, 'Venonat',     'Bug',      'Poison',  1.0,  30.0,  'Lives in the shadows of tall trees where it eats insects. It is attracted by light at night.',            60,  55,  50,  40,  55,  45,  false, false),
(49, 'Venomoth',    'Bug',      'Poison',  1.5,  12.5,  'The powdery scales on its wings are hard to remove from skin. They also contain poison that causes paralysis.', 70, 65, 60, 90, 75, 90, false, false),
(50, 'Diglett',     'Ground',   NULL,      0.2,  0.8,   'Lives about one yard underground where it feeds on plant roots. It sometimes appears above ground.',      10,  55,  25,  35,  45,  95,  false, false),
(51, 'Dugtrio',     'Ground',   NULL,      0.7,  33.3,  'A team of Diglett triplets. It triggers huge earthquakes by burrowing 60 miles underground.',             35,  100, 50,  50,  70,  120, false, false),
